    - Klorida
    - Asetat
    - Sitrat
    answersEN:
    - Sulfuric
    - Hydrochloric
    - Acetic
    - Citric
    correctIndex: 1
  - questionID: 'Waktu rata-rata mencerna makanan:'
    questionEN: 'Average digestion time:'
    answersID:
    - 1 jam
    - "2\u20133 jam"
    - "4\u20135 jam"
    - 12 jam
    answersEN:
    - 1 hr
    - "2\u20133 hr"
    - "4\u20135 hr"
    - 12 hr
    correctIndex: 2
